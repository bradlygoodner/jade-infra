# =============================================================================
# docker/baserow/.env
# Copy this to .env and fill in all values marked CHANGE_ME
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
# =============================================================================

# ── Paths ─────────────────────────────────────────────────────────────────────
# Must match the mkdir structure you created
DOCKER_DATA_PATH=/docker/volumes/propertyops

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/Chicago

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=baserow
POSTGRES_USER=baserow
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME

# ── Baserow ───────────────────────────────────────────────────────────────────
BASEROW_PUBLIC_URL=https://baserow.example.com
BASEROW_CADDY_ADDRESSES=:80
BASEROW_EXTRA_ALLOWED_HOSTS=baserow.example.com
# Generate with: openssl rand -base64 32
SECRET_KEY=CHANGE_ME

# Controls both gunicorn workers AND celery concurrency per queue
# 3 is good for 8 vCPUs with 16GB RAM
BASEROW_AMOUNT_OF_WORKERS=3

# Recycle each gunicorn worker after N requests — sheds leaked FDs from Pillow's
# upload pipeline before they accumulate. Workers exit one at a time (no downtime).
# Jitter prevents all 3 workers recycling at the same moment.
GUNICORN_CMD_ARGS=--max-requests=500 --max-requests-jitter=50

# Port exposed on host — Cloudflare tunnel proxies this
BASEROW_PORT=8086
# Allow internal Docker network access without Host header rewriting
BASEROW_EXTRA_PUBLIC_URLS=http://propertyops-baserow

# File upload limit — default 2.5MB is too small for property photos (phones shoot 5-15MB)
BASEROW_FILE_UPLOAD_SIZE_LIMIT_MB=20

# Max row import size (CSV/JSON with embedded data)
BASEROW_MAX_FILE_IMPORT_SIZE_MB=512

# Skip template sync on every restart — saves ~2s startup and reduces log noise
BASEROW_TRIGGER_SYNC_TEMPLATES_AFTER_MIGRATION=false

# Audit log retention (days) — prevents unbounded table growth
BASEROW_AUDIT_LOG_CLEANUP_INTERVAL_MINUTES=1440
BASEROW_AUDIT_LOG_RETENTION_DAYS=90
