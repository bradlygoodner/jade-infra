# =============================================================================
# docker/n8n/.env
# Copy to .env and fill in all CHANGE_ME values
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
# =============================================================================

# ── Paths ─────────────────────────────────────────────────────────────────────
DOCKER_DATA_PATH=/root/docker/volumes

# ── Backups bind-mount override (optional) ───────────────────────────────────
# Set if your backups live somewhere other than /root/docker/backups
# BACKUP_HOST_PATH=/root/docker/backups

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/Chicago
GENERIC_TIMEZONE=America/Chicago

# ── n8n URLs ──────────────────────────────────────────────────────────────────
N8N_HOST=n8n.example.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.example.com
N8N_EDITOR_BASE_URL=https://n8n.example.com

# ── n8n Auth (locks the editor UI — always enable on an exposed service) ─────
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=CHANGE_ME
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is the default — no extra config needed at this scale
# Data lives in the mounted volume at /home/node/.n8n/database.sqlite

# ── Performance ───────────────────────────────────────────────────────────────
NODE_OPTIONS=--max-old-space-size=2048
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=168              # keep execution history for 7 days

# ── Port ──────────────────────────────────────────────────────────────────────
N8N_PORT=5678
# Generate in the n8n UI: Settings → n8n API → Create API key
N8N_OPS_API_KEY=CHANGE_ME


# ── Code Node Module Allowlist ─────────────────────────────────────────────
NODE_FUNCTION_ALLOW_BUILTIN=crypto

# ── File Access ───────────────────────────────────────────────────────────
N8N_RESTRICT_FILE_ACCESS_TO=/home/node/.n8n-files;/root/docker/backups
