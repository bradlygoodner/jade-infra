# =============================================================================
# docker/docuseal/.env
# Copy to .env and fill in CHANGE_ME values
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
# =============================================================================

# Path to volume directory
DOCKER_DATA_PATH=/root/docker/volumes

# Port exposed on host
DOCUSEAL_PORT=3001

# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=CHANGE_ME
