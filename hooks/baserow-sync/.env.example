# =============================================================================
# hooks/baserow-sync/.env
# Copy to .env and fill in CHANGE_ME values
#   cp .env.example .env
#   chmod 600 .env
#   $EDITOR .env
# =============================================================================

BASEROW_BASE_URL=https://baserow.example.com
# Generate a Baserow database token with read/write on the jade-ops + plants tables
BASEROW_TOKEN=CHANGE_ME
JADE_OPS_TABLE_ID=668
PLANTS_TABLE_ID=815
SESSION_LOG_ROW_ID=7
